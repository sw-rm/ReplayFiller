{
  "name": "replayfill",
  "version": "1.0.0",
  "description": "A mineflayer bot to automate filling replays on Hypixel. Supports multiple accounts - each account's login tokens are cached locally inside the project folder, so no external files are created and switching between accounts is seamless.",
  "main": "replayfill.js",
  "bin": "replayfill.js",
  "dependencies": {
    "mineflayer": "github:aesthetic0001/mineflayer"
  },
  "scripts": {
    "build": "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --out-path dist",
    "build:win": "pkg . --targets node18-win-x64 --out-path dist",
    "build:linux": "pkg . --targets node18-linux-x64 --out-path dist",
    "build:mac": "pkg . --targets node18-macos-x64 --out-path dist"
  },
  "pkg": {
    "assets": [],
    "scripts": [
      "replayfill.js",
      "BotWorker.js"
    ]
  },
  "keywords": [],
  "author": "Swirm",
  "license": "ISC",
  "type": "commonjs"
}
